# Copy to .env and fill in. serverless reads these via ${env:...} in serverless.yml.
# (Use `serverless-dotenv-plugin`, direnv, or export them in your shell / CI before deploy.)

# MongoDB Atlas connection string (mongodb+srv://user:pass@cluster/...).
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.example.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=pdfvault

# Secret for signing JWTs — use a long random string.
JWT_SECRET=change-me-to-a-long-random-string
JWT_TTL_SECONDS=2592000

# Base64 of 32 random bytes, used to encrypt S3 secret keys at rest (AES-256-GCM).
# Generate with:  openssl rand -base64 32
ENCRYPTION_KEY=change-me-base64-of-32-bytes
